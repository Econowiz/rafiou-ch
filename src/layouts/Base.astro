---
import "../styles/global.css";
import TopNav from "../components/ui/TopNav.astro";

interface Props {
  title?: string;
  description?: string;
  activeNav?: "about" | "finance" | "engineering" | "writing" | "contact";
}

const {
  title = "Franck Rafiou-Doué",
  description = "Financial controller, software engineer, and data analyst based in Lucerne.",
  activeNav,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title === "Franck Rafiou-Doué" ? title : `${title} — Franck Rafiou-Doué`}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Source+Serif+4:ital,wght@0,400;0,500;1,400;1,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[var(--color-bg-secondary)] text-[var(--color-text-primary)]">
    <TopNav active={activeNav} />
    <main>
      <slot />
    </main>
  </body>
</html>
