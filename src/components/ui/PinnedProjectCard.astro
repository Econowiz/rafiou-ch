---
type Category = "Operations" | "Analytics" | "Bridge" | "Systems";
type Status = "Public" | "Private" | "Alpha" | "Planned";

interface Props {
  title: string;
  description: string;
  result: string;
  category: Category;
  status?: Status;
  stack: string[];
  href?: string;
}

const { title, description, result, category, status, stack, href } = Astro.props;

const categoryVars: Record<Category, { bg: string; text: string }> = {
  Operations: { bg: "var(--color-operations-bg)", text: "var(--color-operations-text)" },
  Analytics:  { bg: "var(--color-analytics-bg)",  text: "var(--color-analytics-text)"  },
  Bridge:     { bg: "var(--color-bridge-bg)",      text: "var(--color-bridge-text)"      },
  Systems:    { bg: "var(--color-systems-bg)",     text: "var(--color-systems-text)"     },
};

const colors = categoryVars[category];
const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  class="group flex flex-col sm:flex-row border-t border-r border-b border-[var(--color-border-tertiary)] rounded-lg bg-[var(--color-bg-primary)] overflow-hidden hover:-translate-y-0.5 hover:border-[var(--color-border-secondary)] transition-all duration-150"
  style="border-left: 3px solid var(--color-sage);"
>
  <!-- Thumbnail -->
  <div
    class="sm:w-40 h-[72px] sm:h-auto flex-shrink-0 flex items-center justify-center"
    style={`background-color: ${colors.bg};`}
  >
    <span class="font-mono text-[10px] uppercase tracking-[0.06em]" style={`color: ${colors.text};`}>
      {category}
    </span>
  </div>

  <!-- Content -->
  <div class="flex flex-col gap-2 p-4 flex-1">
    <!-- Labels -->
    <div class="flex flex-wrap gap-1.5 items-center">
      <span class="font-mono text-[10px] uppercase tracking-[0.06em] text-[var(--color-text-tertiary)]">
        pinned
      </span>
      <span
        class="rounded-full px-2 py-0.5 text-[10px] font-mono"
        style={`background-color: ${colors.bg}; color: ${colors.text};`}
      >
        {category}
      </span>
      {status && (
        <span class="rounded-full px-2 py-0.5 text-[10px] font-mono bg-[var(--color-bg-tertiary)] text-[var(--color-text-tertiary)]">
          {status}
        </span>
      )}
    </div>

    <!-- Title -->
    <h3 class="font-serif text-[15px] font-[500] text-[var(--color-text-primary)] leading-snug">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-[12.5px] text-[var(--color-text-secondary)] leading-relaxed">
      {description}
    </p>

    <!-- Result -->
    <p
      class="text-[12.5px] text-[var(--color-text-secondary)] leading-relaxed pl-3"
      style="border-left: 2px solid var(--color-sage);"
    >
      {result}
    </p>

    <!-- Stack -->
    <div class="flex flex-wrap gap-1 pt-1">
      {stack.map((s) => (
        <span class="font-mono text-[10px] uppercase tracking-[0.04em] text-[var(--color-text-tertiary)] bg-[var(--color-bg-tertiary)] rounded px-1.5 py-0.5">
          {s}
        </span>
      ))}
    </div>
  </div>
</Tag>
