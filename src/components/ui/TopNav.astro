---
interface Props {
  active?: "about" | "finance" | "engineering" | "writing" | "contact";
}

const { active } = Astro.props;

const links = [
  { href: "/about", label: "About" },
  { href: "/finance", label: "Finance" },
  { href: "/engineering", label: "Engineering" },
  { href: "/writing", label: "Writing" },
  { href: "/contact", label: "Contact" },
] as const;
---

<header class="border-b border-[var(--color-border-tertiary)] bg-[var(--color-bg-primary)]">
  <nav class="mx-auto flex max-w-3xl flex-wrap items-center justify-between px-[var(--spacing-page)] py-4">
    <a
      href="/"
      class="font-serif text-[13.5px] font-[500] text-[var(--color-text-primary)] hover:text-[var(--color-sage)] transition-colors"
    >
      Franck Rafiou-Doué
    </a>
    <ul class="flex flex-wrap gap-x-6 gap-y-1">
      {
        links.map(({ href, label }) => {
          const isActive = active === label.toLowerCase();
          return (
            <li>
              <a
                href={href}
                class:list={[
                  "text-[13px] transition-colors pb-[2px]",
                  isActive
                    ? "text-[var(--color-text-primary)] border-b-2 border-[var(--color-sage)]"
                    : "text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)]",
                ]}
              >
                {label}
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>
</header>
