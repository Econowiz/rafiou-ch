---
interface InfoItem {
  label: string;
  value: string;
}
interface Props {
  items: InfoItem[];
}
const { items } = Astro.props;
---

<div class="border-t border-b border-[var(--color-border-tertiary)] py-5">
  <div class="flex flex-wrap gap-x-10 gap-y-4">
    {items.map(({ label, value }) => (
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.06em] text-[var(--color-text-secondary)] mb-1">
          {label}
        </p>
        <p class="text-[13px] text-[var(--color-text-primary)]">{value}</p>
      </div>
    ))}
  </div>
</div>
